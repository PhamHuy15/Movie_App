generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id String @id @default(cuid())
  name String?
  email String @unique
  passwordHash String?
  image String?
  createdAt DateTime @default(now())
  favorites Favorite[]
  histories WatchHistory[]
  preferences UserPreference?
  interactions MovieInteraction[]
  ratings Rating[]
}
model Favorite {
  id String @id @default(cuid())
  userId String
  movieId Int
  slug String
  title String
  posterUrl String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, movieId])
}
model WatchHistory {
  id String @id @default(cuid())
  userId String
  movieId Int
  slug String
  title String
  posterUrl String
  progress Float @default(0)
  duration Float @default(0)
  updatedAt DateTime @updatedAt
  season Int?
  episode Int?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, movieId])
}

model UserPreference {
  id String @id @default(cuid())
  userId String @unique
  genres Json?
  countries Json?
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MovieInteraction {
  id String @id @default(cuid())
  userId String
  movieId Int
  type String
  value Float?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([movieId, type])
}

model Rating {
  id String @id @default(cuid())
  userId String
  movieId Int
  value Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, movieId])
}

model MovieSourceMapping {
  id              String   @id @default(cuid())
  nguoncSlug      String
  provider        String
  type            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sources         StreamSourceRecord[]
  @@unique([provider, nguoncSlug])
  @@index([nguoncSlug])
}

model StreamSourceRecord {
  id          String   @id @default(cuid())
  mappingId   String
  serverName  String
  type        String
  url         String
  quality     String?
  season      Int?
  episode     Int?
  subtitles   Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mapping     MovieSourceMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  @@index([mappingId, season, episode, enabled])
}
